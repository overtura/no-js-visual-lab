{
  "name": "No-JS Visual Lab",
  "kind": "html-css-only-visual-lab",
  "runtime": "Static HTML + CSS + Vite build only",
  "language": "ko",
  "goal": "JavaScript 없이 최신 HTML/CSS 기능을 시각 실험으로 모으고, 자동 PR로 데모와 문서를 안전하게 개선한다.",
  "allowedChangeScope": [
    "index.html",
    "styles.css",
    "design-system/**",
    "DESIGN.md",
    "README.md",
    "docs/**",
    ".github/workflows/**",
    ".github/prompts/**",
    "self-improvement/**",
    "scripts/**",
    "package.json"
  ],
  "blockedChangeScope": [
    "src/**",
    ".env*",
    "*.pem",
    "*.key",
    ".npmrc",
    "런타임 JavaScript",
    "실제 API key 또는 credential"
  ],
  "qualityGates": [
    "pnpm self-improve:guard",
    "pnpm check"
  ]
}
