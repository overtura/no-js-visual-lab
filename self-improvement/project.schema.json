{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "overtura self-improvement project manifest",
  "type": "object",
  "required": ["name", "kind", "runtime", "goal", "allowedChangeScope", "blockedChangeScope"],
  "properties": {
    "name": { "type": "string" },
    "kind": { "type": "string" },
    "runtime": { "type": "string" },
    "goal": { "type": "string" },
    "allowedChangeScope": {
      "type": "array",
      "items": { "type": "string" }
    },
    "blockedChangeScope": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
